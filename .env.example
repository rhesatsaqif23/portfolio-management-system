# Supabase Database (Direct connection for Drizzle ORM)
# Find this in Supabase Dashboard > Project Settings > Database > Connection string
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# Supabase Storage (Admin client)
# SUPABASE_URL is the project URL, SERVICE_KEY is the service_role key from Settings > API
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJxxx

# Supabase Client-side
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxx

# App
VITE_APP_TITLE=Portfolio CMS
